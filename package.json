{
  "name": "oasis-editor",
  "version": "0.0.81",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/celsowm/oasis-editor.git"
  },
  "main": "./dist/oasis-editor.umd.cjs",
  "module": "./dist/oasis-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oasis-editor.js",
      "require": "./dist/oasis-editor.umd.cjs"
    },
    "./style.css": "./dist/oasis-editor.css",
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    }
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "brand:generate": "node ./scripts/generate-brand-assets.mjs",
    "dev": "vite",
    "build:lib": "vite build --mode lib && node ./scripts/build-adapters.mjs",
    "build:app": "vite build",
    "build": "npm run build:lib && npm run build:app",
    "prepack": "npm run build:lib",
    "preview": "vite preview",
    "test:perf": "playwright test",
    "wasm:build": "wasm-pack build ./rust-core --target web --out-dir ../public/wasm",
    "dev:rust": "npm run wasm:build && vite",
    "build:all": "npm run wasm:build && npm run build",
    "test": "vitest run",
    "test:word-parity": "vitest run --config vitest.word-parity.config.js",
    "check:imports": "node ./scripts/check-import-graph.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20.0.0",
    "@types/web": "^0.0.115",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "prettier": "^3.2.5",
    "terser": "^5.46.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^3.7.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "brotli": "^1.3.3",
    "jszip": "^3.10.1",
    "lucide": "^1.11.0",
    "solid-js": "^1.9.12"
  }
}
